require('dotenv').config();
const express = require('express');
const cors = require('cors');
const helmet = require('helmet');
const morgan = require('morgan');
const mongoose = require('mongoose');

const app = express();
const path = require("path");
app.use(express.static(path.join(__dirname, "../public")));
// Root path handler - FIX FOR 404 ERROR
app.get('/', (req, res) => {
  res.json({
    message: 'Inaya Hotel Management System',
    version: '4.0.0',
    status: 'running',
    endpoints: {
      health: '/api/health',
      api: '/api',
      admin: '/admin-panel.html'
    }
  });
});
const PORT = process.env.PORT || 3000;

// MongoDB Connection
const connectDB = async () => {
  try {
    await mongoose.connect(process.env.MONGO_URI || 'mongodb://localhost:27017/inaya_hotel');
    console.log('✅ MongoDB Connected');
  } catch (err) {
    console.error('❌ MongoDB Error:', err.message);
  }
};

// Middleware
app.use(helmet({ contentSecurityPolicy: false }));
app.use(cors({ origin: '*', credentials: true }));
app.use(express.json());
app.use(morgan('dev'));

// Health Check
app.get('/api/health', (req, res) => {
  res.json({ success: true, status: 'OK', timestamp: new Date().toISOString() });
});

app.get('/api', (req, res) => {
  res.json({ name: 'Inaya Hotel System', version: '4.0.0', status: 'running' });
});

// Start Server
connectDB();
app.listen(PORT, '0.0.0.0', () => {
  console.log(`
  🏨 Inaya Hotel Server
  🚀 Running on port: ${PORT}
  🏥 Health: http://localhost:${PORT}/api/health
  `);
});
