const express = require('express');
const path = require('path');
const { MongoClient } = require('mongodb');

const app = express();
app.use(express.json());
app.use(express.static(path.join(__dirname, '../inaya-hotel/public')));

// Get port from environment
const PORT = process.env.PORT || 8080;
const MONGODB_URI = process.env.MONGO_URI || 'mongodb+srv://hotel:hotelinaya@cluster0.hauipx7.mongodb.net/inaya_hotel?retryWrites=true&w=majority&appName=Cluster0';
const DB_NAME = 'inaya_hotel';

let db;
let client;

async function connectDB() {
    try {
        console.log('🔄 Connecting to MongoDB Atlas...');
        client = new MongoClient(MONGODB_URI);
        await client.connect();
        db = client.db(DB_NAME);
        await db.command({ ping: 1 });
        console.log('✅ MongoDB Connected Successfully!');
        return db;
    } catch (error) {
        console.error('❌ MongoDB Error:', error.message);
        return null;
    }
}

// API Routes
app.get('/api/health', (req, res) => {
    res.json({ 
        success: true, 
        status: 'OK', 
        message: 'Inaya Hotel API',
        mongodb: db ? 'connected' : 'connecting...',
        timestamp: new Date().toISOString()
    });
});

app.get('/api/rooms', async (req, res) => {
    if (!db) {
        return res.json({ success: true, data: [], message: 'Loading rooms...' });
    }
    try {
        const rooms = await db.collection('rooms').find({}).limit(10).toArray();
        res.json({ success: true, data: rooms });
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

app.get('/api/rooms/available', async (req, res) => {
    if (!db) {
        return res.json({ success: true, data: [], message: 'Loading...' });
    }
    try {
        const rooms = await db.collection('rooms').find({ 
            status: { $in: ['Vacant', 'available'] }
        }).limit(10).toArray();
        res.json({ success: true, data: rooms });
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

app.post('/api/bookings', async (req, res) => {
    if (!db) {
        return res.status(503).json({ error: 'Database connecting...' });
    }
    try {
        const { roomNumber, customerName, checkIn, checkOut, guests, phone, email } = req.body;
        
        const room = await db.collection('rooms').findOne({ number: parseInt(roomNumber) });
        if (!room) return res.status(404).json({ error: 'Room not found' });
        
        if (room.status !== 'Vacant') {
            return res.status(400).json({ error: 'Room not available' });
        }
        
        const booking = {
            bookingId: 'BOOK' + Date.now(),
            roomNumber: parseInt(roomNumber),
            roomType: room.type,
            customerName,
            phone,
            email,
            checkIn: new Date(checkIn),
            checkOut: new Date(checkOut),
            guests: parseInt(guests),
            totalPrice: room.price * parseInt(guests),
            bookingDate: new Date(),
            status: 'confirmed'
        };
        
        await db.collection('bookings').insertOne(booking);
        await db.collection('rooms').updateOne(
            { number: parseInt(roomNumber) },
            { $set: { status: 'Occupied', guestName: customerName } }
        );
        
        res.json({ success: true, message: 'Booking confirmed!', bookingId: booking.bookingId });
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

app.get('/admin', (req, res) => {
    res.sendFile(path.join(__dirname, '../inaya-hotel/public/admin.html'));
});

app.get('/', (req, res) => {
    res.sendFile(path.join(__dirname, '../inaya-hotel/public/index.html'));
});

// Start server
app.listen(PORT, '0.0.0.0', async () => {
    console.log(`\n🚀 Inaya Hotel Server Started!`);
    console.log(`🌐 URL: http://localhost:${PORT}`);
    if (process.env.REPL_SLUG) {
        console.log(`🌍 Public URL: https://${process.env.REPL_SLUG}.${process.env.REPL_OWNER}.repl.co`);
    }
    console.log(`🔍 Health Check: http://localhost:${PORT}/api/health\n`);
    
    // Connect to MongoDB in background
    setTimeout(() => connectDB(), 1000);
});

// Graceful shutdown
process.on('SIGTERM', () => {
    console.log('Shutting down...');
    if (client) client.close();
    process.exit(0);
});
