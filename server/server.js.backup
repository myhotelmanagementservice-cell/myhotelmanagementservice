});

// Cancel booking
app.delete('/api/admin/bookings/:id', async (req, res) => {
    const db = await connectDB();
    if (!db) return res.status(503).json({ success: false, error: 'Database not connected' });
    
    try {
        const booking = await db.collection('bookings').findOne({ _id: req.params.id });
        if (booking) {
            await db.collection('rooms').updateOne({ number: booking.roomNumber }, { $set: { status: 'Vacant' } });
            await db.collection('bookings').deleteOne({ _id: req.params.id });
        }
        res.json({ success: true });
    } catch (error) {
        res.status(500).json({ success: false, error: error.message });
    }
});

// Get dashboard stats
app.get('/api/admin/stats', async (req, res) => {
    const db = await connectDB();
    if (!db) return res.status(503).json({ success: false, data: {} });
    
    try {
        const rooms = await db.collection('rooms').find({}).toArray();
        const bookings = await db.collection('bookings').find({}).toArray();
        const totalRevenue = bookings.reduce((sum, b) => sum + (b.totalPrice || 0), 0);
        
        res.json({
            success: true,
            data: {
                totalRooms: rooms.length,
                occupiedRooms: rooms.filter(r => r.status === 'Occupied').length,
                vacantRooms: rooms.filter(r => r.status === 'Vacant').length,
                cleaningRooms: rooms.filter(r => r.status === 'Cleaning').length,
                totalBookings: bookings.length,
                totalRevenue,
                occupancyRate: ((rooms.filter(r => r.status === 'Occupied').length / rooms.length) * 100).toFixed(2)
            }
        });
    } catch (error) {
        res.status(500).json({ success: false, error: error.message });
    }
});

// Get all guests (from bookings)
app.get('/api/admin/guests', async (req, res) => {
    const db = await connectDB();
    if (!db) return res.status(503).json({ success: false, data: [] });
    
    try {
        const guests = await db.collection('bookings').aggregate([
            { $group: { _id: '$email', name: { $first: '$customerName' }, phone: { $first: '$phone' }, totalSpent: { $sum: '$totalPrice' }, bookings: { $push: '$$ROOT' } } }
        ]).toArray();
        res.json({ success: true, data: guests });
    } catch (error) {
        res.status(500).json({ success: false, error: error.message });
    }
});

