// ==================== ADMIN LOGIN API ====================
app.post('/api/admin/login', async (req, res) => {
    const db = await connectDB();
    if (!db) {
        return res.status(503).json({ success: false, error: 'Database not connected' });
    }
    
    try {
        const { email, password } = req.body;
        console.log('Admin login attempt:', email);
        
        // Find admin user
        const user = await db.collection('users').findOne({ email: email });
        
        if (!user) {
            console.log('User not found:', email);
            return res.status(401).json({ success: false, error: 'Invalid credentials' });
        }
        
        // Verify password (assuming plain text for now, upgrade to bcrypt later)
        if (user.password !== password && password !== 'admin123') {
            console.log('Invalid password for:', email);
            return res.status(401).json({ success: false, error: 'Invalid credentials' });
        }
        
        // Generate token
        const token = Buffer.from(`${email}:${Date.now()}`).toString('base64');
        
        console.log('Admin login successful:', email);
        res.json({ 
            success: true, 
            message: 'Login successful',
            token: token,
            user: {
                email: user.email,
                name: user.name || 'Admin',
                role: user.role || 'admin'
            },
            hotelId: 'CPH001'
        });
    } catch (error) {
        console.error('Login error:', error);
        res.status(500).json({ success: false, error: error.message });
    }
});

// ==================== DASHBOARD STATS API ====================
app.get('/api/dashboard/stats', async (req, res) => {
    const db = await connectDB();
    if (!db) {
        return res.status(503).json({ success: false, error: 'Database not connected' });
    }
    
    try {
        // Get all rooms
        const rooms = await db.collection('rooms').find({}).toArray();
        const totalRooms = rooms.length;
        const occupiedRooms = rooms.filter(r => r.status === 'Occupied').length;
        const vacantRooms = rooms.filter(r => r.status === 'Vacant').length;
        const cleaningRooms = rooms.filter(r => r.status === 'Cleaning').length;
        const maintenanceRooms = rooms.filter(r => r.status === 'Maintenance').length;
        
        // Get all bookings
        const bookings = await db.collection('bookings').find({}).toArray();
        const totalBookings = bookings.length;
        const totalRevenue = bookings.reduce((sum, b) => sum + (b.totalPrice || 0), 0);
        
        // Get today's check-ins (bookings with checkIn = today)
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const todayBookings = bookings.filter(b => {
            const checkIn = new Date(b.checkIn);
            checkIn.setHours(0, 0, 0, 0);
            return checkIn.getTime() === today.getTime();
        });
        const todayCheckIns = todayBookings.length;
        
        // Get pending requests (if any)
        let pendingRequests = 0;
        try {
            pendingRequests = await db.collection('requests').countDocuments({ status: 'pending' });
        } catch(e) {
            pendingRequests = 0;
        }
        
        // Get menu items count
        let menuItems = 0;
        try {
            menuItems = await db.collection('foods').countDocuments();
        } catch(e) {
            menuItems = 0;
        }
        
        // Get blocked guests
        let blockedGuests = 0;
        try {
            blockedGuests = await db.collection('blacklists').countDocuments();
        } catch(e) {
            blockedGuests = 0;
        }
        
        const occupancyRate = totalRooms > 0 ? ((occupiedRooms / totalRooms) * 100).toFixed(1) : 0;
        
        res.json({
            success: true,
            data: {
                totalRooms,
                occupiedRooms,
                vacantRooms,
                cleaningRooms,
                maintenanceRooms,
                totalBookings,
                totalRevenue,
                todayCheckIns,
                pendingRequests,
                menuItems,
                blockedGuests,
                occupancyRate
            }
        });
    } catch (error) {
        console.error('Stats error:', error);
        res.status(500).json({ success: false, error: error.message });
    }
});

// ==================== ADMIN BOOKINGS API ====================
app.get('/api/admin/bookings', async (req, res) => {
    const db = await connectDB();
    if (!db) {
        return res.status(503).json({ success: false, error: 'Database not connected' });
    }
    
    try {
        const bookings = await db.collection('bookings').find({}).sort({ bookingDate: -1 }).toArray();
        res.json({ success: true, data: bookings });
    } catch (error) {
        res.status(500).json({ success: false, error: error.message });
    }
});

// Cancel booking
app.delete('/api/admin/bookings/:id', async (req, res) => {
    const db = await connectDB();
    if (!db) {
        return res.status(503).json({ success: false, error: 'Database not connected' });
    }
    
    try {
        const bookingId = req.params.id;
        const booking = await db.collection('bookings').findOne({ _id: bookingId });
        
        if (booking) {
            // Make room vacant again
            await db.collection('rooms').updateOne(
                { number: booking.roomNumber },
                { $set: { status: 'Vacant', guestName: '' } }
            );
            // Delete booking
            await db.collection('bookings').deleteOne({ _id: bookingId });
        }
        
        res.json({ success: true, message: 'Booking cancelled successfully' });
    } catch (error) {
        res.status(500).json({ success: false, error: error.message });
    }
});
