run = "node server/server.js"
language = "nodejs"
modules = ["nodejs-20"]

[deployment]
run = ["node", "server/server.js"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true

[nix]
packages = ["nano"]
